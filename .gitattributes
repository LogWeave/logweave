# Auto detect text files and normalize line endings
* text=auto

# Force LF for files that must work in Linux containers
*.sh text eol=lf
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Force LF for config files
*.json text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
