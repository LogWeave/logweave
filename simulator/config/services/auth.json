{
  "service": "auth-api",
  "environment": "production",
  "metadata": {
    "team": "identity",
    "region": "us-east-1"
  },
  "generators": {
    "username": {
      "type": "choice",
      "values": [
        "jsmith",
        "agarcia",
        "mwilson",
        "kpatel",
        "ljohnson",
        "rbrown",
        "cdavis",
        "nthompson",
        "ewright",
        "dkim",
        "fmorales",
        "hlee",
        "omartin",
        "tchen",
        "wrobinson"
      ]
    },
    "client_ip": {
      "type": "ip"
    },
    "session_id": {
      "type": "uuid"
    },
    "request_id": {
      "type": "uuid"
    },
    "auth_duration_ms": {
      "type": "int",
      "min": 12,
      "max": 380
    },
    "user_agent": {
      "type": "choice",
      "values": [
        "Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/124.0",
        "Mozilla/5.0 (Macintosh; Intel Mac OS X 14_4) Safari/17.4",
        "Mozilla/5.0 (Linux; Android 14) Mobile Chrome/124.0",
        "Mozilla/5.0 (iPhone; CPU iPhone OS 17_4) Safari/604.1",
        "okhttp/4.12.0",
        "PostmanRuntime/7.36.1",
        "axios/1.6.7"
      ]
    },
    "auth_method": {
      "type": "weighted_choice",
      "values": [
        { "value": "password", "weight": 50 },
        { "value": "sso_google", "weight": 20 },
        { "value": "sso_okta", "weight": 15 },
        { "value": "api_key", "weight": 10 },
        { "value": "magic_link", "weight": 5 }
      ]
    },
    "failed_attempts": {
      "type": "int",
      "min": 3,
      "max": 10
    },
    "mfa_method": {
      "type": "choice",
      "values": ["totp", "sms", "email", "webauthn"]
    },
    "lockout_duration_minutes": {
      "type": "choice",
      "values": [15, 30, 60]
    },
    "permission": {
      "type": "choice",
      "values": [
        "admin:write",
        "billing:read",
        "users:delete",
        "reports:export",
        "settings:write",
        "audit:read"
      ]
    },
    "token_ttl_seconds": {
      "type": "choice",
      "values": [900, 1800, 3600, 7200]
    }
  },
  "templates": [
    {
      "message": "User {{username}} authenticated successfully via {{auth_method}} from {{client_ip}} in {{auth_duration_ms}}ms",
      "level": "info",
      "weight": 45,
      "fields": {
        "event": "auth.login.success",
        "session_id": { "$gen": "session_id" },
        "request_id": { "$gen": "request_id" },
        "duration_ms": { "$gen": "auth_duration_ms" },
        "user_agent": { "$gen": "user_agent" }
      }
    },
    {
      "message": "Failed login attempt for user {{username}} from {{client_ip}} — invalid credentials (attempt {{failed_attempts}})",
      "level": "warn",
      "weight": 7,
      "fields": {
        "event": "auth.login.failed",
        "request_id": { "$gen": "request_id" },
        "reason": "invalid_credentials",
        "client_ip": { "$gen": "client_ip" },
        "user_agent": { "$gen": "user_agent" }
      }
    },
    {
      "message": "Token refreshed for session {{session_id}} — new TTL {{token_ttl_seconds}}s",
      "level": "info",
      "weight": 22,
      "fields": {
        "event": "auth.token.refresh",
        "request_id": { "$gen": "request_id" },
        "duration_ms": { "$gen": "auth_duration_ms" }
      }
    },
    {
      "message": "MFA challenge sent to {{username}} via {{mfa_method}} from {{client_ip}}",
      "level": "info",
      "weight": 8,
      "fields": {
        "event": "auth.mfa.challenge",
        "session_id": { "$gen": "session_id" },
        "request_id": { "$gen": "request_id" }
      }
    },
    {
      "message": "Account locked for user {{username}} after {{failed_attempts}} consecutive failures — lockout {{lockout_duration_minutes}}min",
      "level": "error",
      "weight": 2,
      "fields": {
        "event": "auth.account.lockout",
        "request_id": { "$gen": "request_id" },
        "client_ip": { "$gen": "client_ip" }
      }
    },
    {
      "message": "Session {{session_id}} expired for user {{username}} — inactive for {{token_ttl_seconds}}s",
      "level": "info",
      "weight": 12,
      "fields": {
        "event": "auth.session.expired",
        "request_id": { "$gen": "request_id" }
      }
    },
    {
      "message": "Permission denied: user {{username}} attempted {{permission}} without required role from {{client_ip}}",
      "level": "warn",
      "weight": 4,
      "fields": {
        "event": "auth.permission.denied",
        "request_id": { "$gen": "request_id" },
        "session_id": { "$gen": "session_id" },
        "user_agent": { "$gen": "user_agent" }
      }
    }
  ],
  "spike": {
    "error_weight_multiplier": 8,
    "extra_templates": [
      {
        "message": "Deploying auth-api v2.14.0-rc3 — rolling restart in progress, {{failed_attempts}} instances draining",
        "level": "warn",
        "weight": 15,
        "fields": {
          "event": "auth.deploy.rolling_restart",
          "request_id": { "$gen": "request_id" },
          "version": "2.14.0-rc3"
        }
      },
      {
        "message": "LDAP connection pool exhausted — 0/{{failed_attempts}} connections available, queuing auth requests from {{client_ip}}",
        "level": "error",
        "weight": 20,
        "fields": {
          "event": "auth.ldap.pool_exhausted",
          "request_id": { "$gen": "request_id" },
          "duration_ms": { "$gen": "auth_duration_ms" }
        }
      },
      {
        "message": "Auth request timeout after {{auth_duration_ms}}ms for user {{username}} — upstream LDAP not responding",
        "level": "error",
        "weight": 12,
        "fields": {
          "event": "auth.ldap.timeout",
          "request_id": { "$gen": "request_id" },
          "client_ip": { "$gen": "client_ip" }
        }
      }
    ]
  }
}
