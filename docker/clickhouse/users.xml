<clickhouse>
    <users>
        <default>
            <!-- Restrict default user to localhost only (health checks) -->
            <networks>
                <ip>127.0.0.1</ip>
                <ip>::1</ip>
            </networks>
        </default>
        <logweave>
            <!-- Application user — password set via CLICKHOUSE_PASSWORD env var -->
            <password_sha256_hex from_env="CLICKHOUSE_PASSWORD_SHA256"/>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>0</access_management>
        </logweave>
    </users>
</clickhouse>
