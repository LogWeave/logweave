# =============================================================================
# LogWeave — Production Environment Variables
# Copy this file: cp .env.production.example .env
# Then edit values below. Lines marked REQUIRED must be set before starting.
# =============================================================================

# ---------------------------------------------------------------------------
# API Server
# ---------------------------------------------------------------------------

# REQUIRED — JSON mapping of API keys to tenant IDs.
# Generate secure keys: openssl rand -hex 32
# Format: {"<api-key>":"<tenant-id>", ...}
LOGWEAVE_API_KEYS={"CHANGE-ME-generate-with-openssl-rand-hex-32":"my-org"}

# REQUIRED — 16+ character key for encrypting S3 connector secrets at rest.
# Generate: openssl rand -hex 16
LOGWEAVE_ENCRYPTION_KEY=CHANGE-ME-generate-with-openssl-rand-hex-16

# API server port (default: 3000)
LOGWEAVE_PORT=3000

# Trust the reverse proxy's X-Forwarded-For for the client IP. The default
# docker-compose.prod.yml runs the API behind Caddy, so set this to true — the
# IP-based login rate limit and account lockout key on the real client IP
# instead of collapsing to the proxy's address. Leave false (or unset) only if
# the API is exposed directly with no proxy in front. Accepts true/false or a
# trusted-hop count (e.g. 2 if there are two proxies).
LOGWEAVE_TRUST_PROXY=true

# Log level: fatal, error, warn, info, debug, trace (default: info)
LOGWEAVE_LOG_LEVEL=info

# Clusterer connection timeout in ms (default: 500, raise for slower networks)
LOGWEAVE_CLUSTERER_TIMEOUT_MS=2000

# Rate limiting — requests per minute
LOGWEAVE_RATE_LIMIT_RPM=300           # per API key
LOGWEAVE_RATE_LIMIT_TENANT_RPM=600    # per tenant (all keys combined)
LOGWEAVE_RATE_LIMIT_INGEST_RPM=600    # ingest endpoint specifically

# Max concurrent ClickHouse queries (default: 8)
LOGWEAVE_MAX_CONCURRENT_QUERIES=8

# Unclustered log recovery (re-clusters template_id=0 logs)
LOGWEAVE_RECOVERY_ENABLED=true
LOGWEAVE_RECOVERY_INTERVAL_MS=60000   # check every 60s
LOGWEAVE_RECOVERY_LOOKBACK_HOURS=24   # look back 24h

# Data retention sweep (default: enabled, runs daily)
LOGWEAVE_RETENTION_ENABLED=true

# Graceful shutdown timeout in ms (default: 10000)
LOGWEAVE_SHUTDOWN_TIMEOUT_MS=10000

# ---------------------------------------------------------------------------
# Clusterer
# ---------------------------------------------------------------------------

# Default clustering similarity threshold (0.0-1.0, default: 0.4)
# Lower = more general patterns, Higher = more specific patterns
# Users can override per-tenant via Settings UI
LOGWEAVE_DRAIN3_SIM_TH=0.4

# Drain3 tree depth (default: 4, rarely needs changing)
LOGWEAVE_DRAIN3_DEPTH=4

# Max clusters per tenant (default: 10000)
LOGWEAVE_DRAIN3_MAX_CLUSTERS=10000

# Max concurrent cluster requests (default: 4)
LOGWEAVE_MAX_CONCURRENT_REQUESTS=4

# Max tenants (default: 200)
LOGWEAVE_MAX_TENANTS=200

# REQUIRED to restore checkpoints across restarts — without it the clusterer
# refuses to load on-disk Drain3 state (unverifiable jsonpickle) and starts fresh.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
LOGWEAVE_CHECKPOINT_HMAC_KEY=

# Shared secret guarding the clusterer's destructive endpoints (/cluster/reset,
# /embed/backfill). Set on BOTH the api and clusterer services to the same value.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
LOGWEAVE_INTERNAL_SECRET=

# ---------------------------------------------------------------------------
# Dashboard (build-time variables — set before building the dashboard image)
# ---------------------------------------------------------------------------

# API URL — leave empty if dashboard is served by the API server (default, recommended)
VITE_LOGWEAVE_API_URL=

# Polling interval in ms (default: 60000)
VITE_POLL_INTERVAL_MS=60000

# NOTE: VITE_LOGWEAVE_API_KEY is intentionally absent.
# Baking an API key into the JS bundle exposes your tenant master credential to
# every browser tab and bypasses the session/TOTP auth system. Use dashboard
# login (username + password) for browser access. API keys are for machines only.

# ---------------------------------------------------------------------------
# ClickHouse (used by docker-compose.prod.yml — do not change prefix)
# ---------------------------------------------------------------------------

CLICKHOUSE_DB=logweave

# REQUIRED for production — ClickHouse authentication (defense-in-depth).
# Generate password: openssl rand -hex 16
# Generate SHA256 hash: echo -n "your-password" | sha256sum | cut -d' ' -f1
LOGWEAVE_CLICKHOUSE_USER=logweave
LOGWEAVE_CLICKHOUSE_PASSWORD=
CLICKHOUSE_PASSWORD_SHA256=

# ---------------------------------------------------------------------------
# Internal service URLs (set by docker-compose, do not change for Docker deploys)
# ---------------------------------------------------------------------------
# LOGWEAVE_CLICKHOUSE_URL=http://clickhouse:8123
# LOGWEAVE_CLUSTERER_URL=http://clusterer:8000
