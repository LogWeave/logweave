# Dashboard configuration
VITE_LOGWEAVE_API_URL=

# API key for the dashboard's own requests. Optional.
#   - Leave EMPTY for the standard deploy: the dashboard authenticates with the
#     API via a session cookie + CSRF token (see src/lib/api-client.ts), set by
#     logging in. This is the recommended path — no key is baked into the bundle.
#   - Set a key only for local dev / legacy single-key setups, where the
#     dashboard sends `Authorization: Bearer <key>` instead.
# Note: this key is NOT the one to paste into ingest snippets — create those in
# Settings → API Keys. The onboarding snippets show a YOUR_API_KEY placeholder
# when this is empty.
VITE_LOGWEAVE_API_KEY=

# Polling interval (milliseconds) — increase for less API load, decrease for live tail
VITE_POLL_INTERVAL_MS=60000
