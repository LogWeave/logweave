# LogWeave Clusterer — Environment Variables
# All settings use the LOGWEAVE_ prefix.

LOGWEAVE_DRAIN3_CHECKPOINT_DIR=/data/drain3
LOGWEAVE_DRAIN3_CHECKPOINT_INTERVAL=60
LOGWEAVE_DRAIN3_SIM_TH=0.4
LOGWEAVE_DRAIN3_DEPTH=4
LOGWEAVE_CLICKHOUSE_URL=clickhouse://localhost:9000/logweave
LOGWEAVE_DRAIN3_MAX_CLUSTERS=10000
LOGWEAVE_MAX_CONCURRENT_REQUESTS=4
LOGWEAVE_REQUEST_TIMEOUT_SECONDS=0.45
LOGWEAVE_MAX_TENANTS=200
LOGWEAVE_CHECKPOINT_HMAC_KEY=
