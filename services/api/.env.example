# Required
LOGWEAVE_CLICKHOUSE_URL=http://localhost:8123
LOGWEAVE_CLUSTERER_URL=http://localhost:8000

# Required — JSON mapping API keys to tenant IDs
# Format: {"api-key-1":"tenant-a","api-key-2":"tenant-b"}
LOGWEAVE_API_KEYS={"dev-key":"dev-tenant"}

# Optional (defaults shown)
LOGWEAVE_PORT=3000
LOGWEAVE_CLUSTERER_TIMEOUT_MS=500
LOGWEAVE_LOG_LEVEL=info
LOGWEAVE_SHUTDOWN_TIMEOUT_MS=10000
LOGWEAVE_RECOVERY_INTERVAL_MS=60000
