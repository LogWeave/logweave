# Required
LOGWEAVE_CLICKHOUSE_URL=http://localhost:8123
LOGWEAVE_CLUSTERER_URL=http://localhost:8000

# Required — JSON mapping API keys to tenant IDs
# Format: {"api-key-1":"tenant-a","api-key-2":"tenant-b"}
LOGWEAVE_API_KEYS={"dev-key":"dev-tenant","e2e-key-tenant-a":"e2e-tenant-a","e2e-key-tenant-b":"e2e-tenant-b"}

# Optional (defaults shown)
LOGWEAVE_PORT=3000
LOGWEAVE_CLUSTERER_TIMEOUT_MS=500
LOGWEAVE_LOG_LEVEL=info
LOGWEAVE_SHUTDOWN_TIMEOUT_MS=10000
LOGWEAVE_RECOVERY_INTERVAL_MS=60000
LOGWEAVE_RECOVERY_LOOKBACK_HOURS=24

# S3 connector — CloudFormation quick-create (optional; only needed if you serve
# customer-facing S3 connectors and want a one-click IAM setup link).
# LOGWEAVE_AWS_ACCOUNT_ID is the 12-digit AWS account that LogWeave runs in;
# customers' trust policies grant sts:AssumeRole to this account.
# LOGWEAVE_S3_CFN_TEMPLATE_URL must be the public HTTPS URL of
# services/api/cloudformation/s3-connector-role.yaml (host it on S3 or a CDN).
# LOGWEAVE_AWS_ACCOUNT_ID=123456789012
# LOGWEAVE_S3_CFN_TEMPLATE_URL=https://logweave-public.s3.amazonaws.com/cfn/s3-connector-role.yaml
