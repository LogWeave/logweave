{
  "name": "logweave-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LogWeave API server — ingestion, dashboard, query endpoints",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "test": "tsx --test src/**/*.test.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "tsx": "^4.19",
    "typescript": "^5.7"
  }
}
