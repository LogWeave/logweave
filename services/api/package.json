{
  "author": "Robert Dicker 2026",
  "name": "logweave-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LogWeave API server — ingestion, dashboard, query endpoints",
  "scripts": {
    "dev": "tsx watch src/index.ts | pino-pretty",
    "start": "node dist/index.js",
    "build": "tsc",
    "test": "tsx scripts/test.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@clickhouse/client": "^1.8.0",
    "express": "^5.1.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^6.0.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19",
    "typescript": "^5.9.0"
  }
}
