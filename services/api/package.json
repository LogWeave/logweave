{
  "author": "Robert Dicker 2026",
  "name": "logweave-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LogWeave API server — ingestion, dashboard, query endpoints",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/index.ts | pino-pretty",
    "start": "node dist/index.js",
    "build": "tsc",
    "test": "tsx scripts/test.ts",
    "test:unit": "tsx scripts/test.ts --unit",
    "test:integration": "tsx scripts/test.ts --integration",
    "test:e2e": "pnpm -C ../../packages/transport build && node --import tsx --test --test-concurrency=1 --test-timeout 300000 tests/e2e/*.integration.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@clickhouse/client": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "otpauth": "^9.5.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "qrcode": "^1.5.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19",
    "typescript": "catalog:"
  }
}
