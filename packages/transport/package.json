{
  "name": "@logweave/transport",
  "version": "0.1.0",
  "description": "Winston transport for LogWeave — buffer, retry, never block",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "homepage": "https://github.com/logweave/logweave/tree/main/packages/transport#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/logweave/logweave.git",
    "directory": "packages/transport"
  },
  "bugs": {
    "url": "https://github.com/logweave/logweave/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "logweave",
    "winston",
    "winston-transport",
    "log-intelligence",
    "observability"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsx scripts/test.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "winston": "^3.0.0",
    "winston-transport": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0"
  }
}
